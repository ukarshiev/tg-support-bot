APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=true

# Manager interface mode: telegram_group | admin_panel
MANAGER_INTERFACE=telegram_group

ALLOWED_ORIGINS="https://example.com,https://admin.example.com"

MAIN_DOMAIN=example.com
APP_URL=https://example.com

# Telegram IPv4 force flag (infrastructure / deployment — stays in .env)
TELEGRAM_FORCE_IPV4=

TG_LOGGER_TOKEN="YOUR_TG_LOGGER_TOKEN_HERE"
TG_LOGGER_CHAT_ID="-1000000000000"

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=10

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=pgdb
DB_PORT=5432
DB_DATABASE=database_name
DB_USERNAME=username
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

#-----------------------
# DOCKER
#-----------------------
CERTBOT_EMAIL=

SYSTEM_TIMEZONE=UTC

NGINX_PORT=80:80
PGDB_PORT=5432:5432

PGADMIN_PORT=5050:80
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin_password

REDIS_CLIENT=predis
REDIS_PORT=6379:6379
REDIS_HOST=redis
REDIS_PASSWORD=redis_password

REDISINSIGHT_PORT=8001:5540

SENTRY_LARAVEL_DSN=
SENTRY_SEND_DEFAULT_PII=false
SENTRY_TRACES_SAMPLE_RATE=0.1

#-----------------------
# LARAVEL TELESCOPE
#-----------------------
# Debug dashboard at /telescope. Access requires APP_DEBUG=true AND HTTP Basic
# auth matching the credentials below (see TelescopeBasicAuth middleware). With
# APP_DEBUG=false the dashboard returns 404; empty credentials deny access.
# Shows requests, exceptions, logs, queries, jobs, cache, redis, etc.
# In `local` everything is recorded; in non-local only failures/exceptions
# /scheduled/monitored entries are kept (see TelescopeServiceProvider::register).
TELESCOPE_ENABLED=true
TELESCOPE_PATH=telescope
TELESCOPE_AUTH_USER=admin
TELESCOPE_AUTH_PASSWORD=change-me

#-----------------------
# LIVE CHAT
#-----------------------
VITE_APP_URL=${APP_URL}

#-----------------------
# CONTACT DATA
#-----------------------
AUTHOR_GITHUB="https://github.com/prog-time"
AUTHOR_GITHUB_PROJECT="https://github.com/prog-time/tg-support-bot"
AUTHOR_WIKI_PAGE="https://github.com/prog-time/tg-support-bot/wiki"
AUTHOR_TG_GROUP="https://t.me/pt_tg_support"
AUTHOR_GITHUB_ISSUES="https://github.com/prog-time/tg-support-bot/issues"

#-----------------------
# TEST DATA
#-----------------------
TEST_USER_CHAT_ID="1234567890"
TEST_USER_USERNAME="username"
TEST_USER_FIRST_NAME="First"
TEST_USER_LAST_NAME="Last"
TEST_PHOTO="TEST_PHOTO_ID"
TEST_DOCUMENT="TEST_DOCUMENT_ID"
TEST_STICKER="TEST_STICKER_ID"
TEST_VIDEO_NOTE="TEST_VIDEO_NOTE_ID"
TEST_VOICE="TEST_VOICE_ID"

TEST_EXTERNAL_SOURCE="phpunit-source"
TEST_EXTERNAL_ID="external_id"

TEST_VK_USER_CHAT_ID="123456789"
TEST_VK_GROUP_ID="123456789"
TEST_VK_SECRET_CODE="YOUR_VK_SECRET_CODE_HERE"

TEST_MAX_USER_CHAT_ID="123456789"
TEST_MAX_SECRET_KEY="YOUR_MAX_SECRET_KEY_HERE"
