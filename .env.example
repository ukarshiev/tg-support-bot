APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=false

MAIN_DOMAIN=example.com
APP_URL=https://example.com

#-----------------------
# БАЗА ДАННЫХ
#-----------------------
DB_CONNECTION=pgsql
DB_HOST=pgdb
DB_PORT=5432
DB_DATABASE=database_name
DB_USERNAME=username
DB_PASSWORD=password

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=10

LOG_CHANNEL=stack
LOG_LEVEL=debug

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

#-----------------------
# REDIS / HORIZON
#-----------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_QUEUE_CONNECTION=queue
REDIS_QUEUE_BLOCK_FOR=5
REDIS_QUEUE_RETRY_AFTER=120
HORIZON_PATH=admin/horizon

#-----------------------
# REVERB / WEBSOCKET
#-----------------------
REVERB_APP_ID=tg-support-bot
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=example.com
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_ALLOWED_ORIGINS=https://example.com
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=example.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

#-----------------------
# DOCKER
#-----------------------
SYSTEM_TIMEZONE=UTC

NGINX_PORT=80:80

PGDB_PORT=5432:5432

#-----------------------
# LARAVEL TELESCOPE
#-----------------------
TELESCOPE_ENABLED=false
TELESCOPE_PATH=telescope

# Telegram IPv4 force flag (infrastructure / deployment — stays in .env)
TELEGRAM_FORCE_IPV4=
TELEGRAM_INGRESS_MODE=polling
